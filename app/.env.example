# ──────────────────────────────────────────────────────────────
# Cortex Analytics — environment configuration
# Copy to ".env" and fill in real values. Never commit .env or your key.
#
# The app runs in a polished DEMO mode (realistic synthetic data) until these
# are set — then it automatically switches to LIVE Snowflake + OpenAI.
# ──────────────────────────────────────────────────────────────

# ---- OpenAI ----------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# ---- Snowflake (key-pair / private key auth) -------------------
SNOWFLAKE_ACCOUNT=your_org-your_account          # e.g. ab12345.eu-west-1
SNOWFLAKE_USER=YOUR_SERVICE_USER
SNOWFLAKE_PRIVATE_KEY_PATH=./keys/rsa_key.p8     # path to PKCS#8 private key
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=                # optional, if key is encrypted
SNOWFLAKE_ROLE=ANALYTICS_READER
SNOWFLAKE_WAREHOUSE=ANALYTICS_WH
SNOWFLAKE_DATABASE=ANALYTICS_DB
SNOWFLAKE_SCHEMA=PRESENTATION
